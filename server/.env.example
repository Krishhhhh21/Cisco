# ── Server ─────────────────────────────────────────────────
PORT=5000

# MongoDB Atlas or local: mongodb://127.0.0.1:27017/packetvault
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/packetvault?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-string

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Comma-separated browser origins allowed to call the API (CORS).
# Add your GitHub Pages site (no trailing slash):
# FRONTEND_ORIGINS=https://yourusername.github.io
FRONTEND_ORIGINS=https://krishhhhh21.github.io

# On Render (API-only): do not serve the bundled /client static files
# SERVE_STATIC=false
